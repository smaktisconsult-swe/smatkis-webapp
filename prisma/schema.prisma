generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LeadInquiry {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  name            String
  email           String
  phone           String?
  clientType      String
  serviceInterest String
  consultationDate String
  consultationTime String
  consultationTimeZone String     @default("Europe/Stockholm")
  consultationDurationMinutes Int @default(30)
  timeline        String?
  budgetRange     String?
  message         String
  consent         Boolean    @default(true)
  source          String     @default("website")
  status          LeadStatus @default(NEW)

  @@unique([consultationDate, consultationTime, consultationTimeZone], name: "LeadInquiry_consultation_slot_key")
}

model BlockedConsultationSlot {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  date           String
  time           String
  timeZone       String   @default("Europe/Stockholm")
  reason         String?
  blockedByEmail String?

  @@unique([date, time, timeZone], name: "BlockedConsultationSlot_slot_key")
  @@index([date, time])
}

model ServiceOffering {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  audience     String
  summary      String
  startingFrom String?
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  clientType  String
  quote       String
  attribution String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResourcePost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  category    String
  readMinutes Int
  body        String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}
